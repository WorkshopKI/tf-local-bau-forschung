{
  "name": "teamflow-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:test-csvs": "node scripts/generate-test-csvs.mjs",
    "generate:test-label-xlsx": "node scripts/generate-test-label-xlsx.mjs",
    "generate:test-assets": "npm run generate:test-csvs && npm run generate:test-label-xlsx",
    "prebuild": "npm run generate:test-assets",
    "prebuild:variant": "npm run generate:test-assets",
    "prebuild:dev": "npm run generate:test-assets",
    "prebuild:demo": "npm run generate:test-assets",
    "prebuild:foerderprogramm": "npm run generate:test-assets",
    "build": "tsc -b && vite build",
    "build:variant": "node scripts/build-with-config.mjs",
    "build:dev": "node scripts/build-with-config.mjs --config configs/dev.config.json",
    "build:demo": "node scripts/build-with-config.mjs --config configs/demo.config.json",
    "build:foerderprogramm": "node scripts/build-with-config.mjs --config configs/foerderprogramm.config.json",
    "config-ui": "node scripts/serve-config-ui.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@huggingface/transformers": "^4.0.1",
    "@orama/orama": "^3.1.18",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.5.207",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.3",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/file-saver": "^2.0.7",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
